 Configuration Files...","category":"Codespaces","icon":{"dark":"images/dark/gear.svg","light":"images/light/gear.svg"}},{"command":"github.codespaces.copyIdToClipboard","title":"Copy ID to Clipboard","category":"Codespaces","icon":{"dark":"images/dark/copy.svg","light":"images/light/copy.svg"}},{"command":"github.codespaces.rebuildEnvironment","title":"Rebuild Container","category":"Codespaces","icon":"$(tools)"},{"command":"github.codespaces.labelPortAndUpdateConfig","title":"Set Label and Update devcontainer.json","category":"Codespaces","enablement":"remoteName == codespaces"},{"command":"github.codespaces.showDetails","title":"Details","category":"Codespaces","enablement":"remoteName == codespaces"},{"command":"github.codespaces.sendFeedback","title":"Send Feedback","category":"Codespaces"},{"command":"github.codespaces.reportIssue","title":"Report Issue","category":"Codespaces"},{"command":"github.codespaces.export","title":"Export Changes to a Branch","category":"Codespaces"},{"command":"github.codespaces.manageUserSecrets","title":"Manage User Secrets","category":"Codespaces"},{"command":"github.codespaces.switchUserAccount","title":"Switch User Account","category":"Codespaces"}],"menus":{"ports/item/context":[{"command":"github.codespaces.labelPortAndUpdateConfig","group":"0_manage@4","when":"tunnelType == Forwarded && remoteName == codespaces"}],"view/title":[{"command":"github.codespaces.addEnvironment","group":"navigation@1","when":"view == github.codespaces.explorer && codespaces:explorerState == Initialized && remoteName != codespaces"},{"command":"github.codespaces.refresh","group":"navigation@3","when":"view == github.codespaces.explorer && codespaces:explorerState == Initialized && remoteName != codespaces"},{"command":"github.codespaces.configureDevContainerSidebar","when":"view == github.codespaces.explorer && remoteName == codespaces","group":"navigation@1"},{"command":"github.codespaces.rebuildEnvironment","when":"view == github.codespaces.explo